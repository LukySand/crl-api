# Conexión Prisma (adapter MariaDB apuntando al MySQL de docker-compose)
DATABASE_URL="mysql://root:CAMBIAR@localhost:3306/crl_db"

# Credenciales del contenedor MySQL (docker-compose)
MYSQL_ROOT_PASSWORD=CAMBIAR
MYSQL_DATABASE=crl_db

# Usadas por prisma/seed.ts
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CAMBIAR

# Auth
JWT_SECRET=cambiar-esto-en-produccion

# Puerto del API (opcional, default 3001)
PORT=3001
